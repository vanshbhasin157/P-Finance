# Copy to .env.local (never commit real keys)
# Supabase: Project Settings -> API
# Authentication -> Sign In / Providers -> enable Email auth (OTP)
#
# Email magic links use a redirect URL. By default the app sends your current
# origin (e.g. http://localhost:5173 for Vite). That exact URL must appear under
# Authentication -> URL Configuration -> Redirect URLs (e.g. http://localhost:5173/**).
# Site URL should match what you use in dev (not localhost:3000 unless the app runs there).
# For production builds, set this explicitly:
# VITE_SUPABASE_REDIRECT_URL=https://your-app.vercel.app

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
